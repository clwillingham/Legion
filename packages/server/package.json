{
  "name": "@legion-collective/server",
  "version": "0.1.0",
  "description": "Legion web server — HTTP + WebSocket interface for the Legion collective",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "web/dist"
  ],
  "scripts": {
    "build": "tsup && npm run build --prefix web",
    "build:server": "tsup",
    "build:web": "npm run build --prefix web",
    "clean": "rm -rf dist web/dist",
    "dev": "tsup --watch"
  },
  "keywords": [
    "ai",
    "agents",
    "multi-agent",
    "llm",
    "collective",
    "orchestration",
    "server",
    "web"
  ],
  "author": "clwillingham",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/clwillingham/Legion.git",
    "directory": "packages/server"
  },
  "homepage": "https://github.com/clwillingham/Legion#readme",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@legion-collective/core": "^0.1.0",
    "fastify": "^5.7.4",
    "@fastify/websocket": "^11.2.0",
    "@fastify/static": "^9.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.2",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0"
  }
}
